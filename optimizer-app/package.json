{
  "name": "optimizer-app",
  "version": "1.0.0",
  "description": "Optimizer - otimizacao real de PC Windows (startup, disco, energia, drivers, servicos)",
  "main": "main.js",
  "author": "Voce",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.optimizer.app",
    "productName": "Optimizer",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "files": [
      "**/*",
      "!dist/**"
    ]
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
